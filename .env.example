ACME_EMAIL="your-email@example.com"
CF_Token="your_cloudflare_token"

# Optional: certificate install path (default: /etc/nginx/ssl)
# SSL_DIR="/etc/nginx/ssl"

# === 資料庫備份設定（backup_databases.sh） ===
# 注意：若密碼含空格或特殊字元（# " ' $ 等），.env 載入會失敗。
#       請避免特殊字元，或使用 base64/僅英數的密碼。

# MariaDB 連線
DB_USER="backup_user"
DB_PASS="your_db_password"
# DB_HOST="localhost"

# 備份路徑（建議放在獨立掛載碟，保護系統碟空間）
BACKUP_DIR="/mnt/your-mount/bakdb/backups"
BACKUP_LOG_DIR="/mnt/your-mount/bakdb/logs"
BACKUP_MOUNT_POINT="/mnt/your-mount"

# 要備份的資料庫名稱（空格分隔）
BACKUP_DBS="db_one db_two"

# 舊檔保留天數（預設 30）
# BACKUP_RETENTION_DAYS=30

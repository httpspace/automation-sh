ACME_EMAIL="your-email@example.com"

# Cloudflare API token
# 必要權限：
#   - Zone:DNS:Edit       （install_acme.sh / install_wildcard_ssl.sh 簽 wildcard 證；webops cf-dns 增刪 record）
#   - Zone:Zone:Read（選） （webops 在 domains.conf 留空 zone_id 時 auto-discover；不用此功能可省）
# 範圍建議：限縮到實際管理的 zones，不要用 Global API Key。
CF_Token="your_cloudflare_token"

# Optional: certificate install path (default: /etc/nginx/ssl)
# SSL_DIR="/etc/nginx/ssl"

# === 資料庫備份設定（backup_databases.sh） ===
# 注意：若密碼含空格或特殊字元（# " ' $ 等），.env 載入會失敗。
#       請避免特殊字元，或使用 base64/僅英數的密碼。

# MariaDB 連線
DB_USER="backup_user"
DB_PASS="your_db_password"
# DB_HOST="localhost"

# 備份路徑（建議放在獨立掛載碟，保護系統碟空間）
BACKUP_DIR="/mnt/your-mount/bakdb/backups"
BACKUP_LOG_DIR="/mnt/your-mount/bakdb/logs"
BACKUP_MOUNT_POINT="/mnt/your-mount"

# 要備份的資料庫名稱（空格分隔）
BACKUP_DBS="db_one db_two"

# 舊檔保留天數（預設 30）
# BACKUP_RETENTION_DAYS=30

# === webops 部署框架 ===
# 主網域註冊表在 webops/domains.conf（gitignore，含 zone_id）
# CF_Token 重用上方 install_acme.sh 的設定（需對 domains.conf 內所有 zone 有 Zone:DNS:Edit）

# 站點根目錄（deploy-site.sh 部署位置；laravel-svc.sh 也讀此值）
WEBOPS_BASE_DIR="/home/svc-app/public_html"

# 站點檔案 owner（svc-app 可改檔；nginx www-data 群組可讀）
WEBOPS_USERNAME="svc-app"

# SSL 憑證路徑（預設 = 上方 SSL_DIR；通常 /etc/nginx/ssl）
# WEBOPS_SSL_PATH="/etc/nginx/ssl"

# PHP-FPM socket（不設則自動偵測 /run/php/php*-fpm.sock 取最新版）
# WEBOPS_PHP_FPM_SOCK="/run/php/php8.3-fpm.sock"
